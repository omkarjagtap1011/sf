<apex:page controller="EmailController">

    <apex:form>

        <!-- Display Messages -->
        <apex:pageMessages />

        <apex:pageBlock title="Send Email Notification">

            <apex:pageBlockSection columns="1">

                <!-- Recipient -->
                <apex:inputText
                    value="{!recipient}"
                    label="Recipient Email"
                />

                <!-- Subject -->
                <apex:inputText
                    value="{!subject}"
                    label="Subject"
                />

                <!-- Body -->
                <apex:inputTextarea
                    value="{!body}"
                    label="Message Body"
                    rows="6"
                />

            </apex:pageBlockSection>

            <!-- Button -->
            <apex:pageBlockButtons>

                <apex:commandButton
                    value="Send Email"
                    action="{!sendEmail}"
                />

            </apex:pageBlockButtons>

        </apex:pageBlock>

    </apex:form>

</apex:page>